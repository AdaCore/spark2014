#!/usr/bin/env python3

import argparse
from e3.fs import sync_tree
from e3.gaia.api import GAIA
from e3.testsuite.report.rewriting import BaseBaselineRewriter
from e3.testsuite.report.index import ReportIndex
from e3.testsuite.result import FailureReason, TestStatus
from e3.testsuite.utils import ColorConfig
from adacore_gitlab_scripts.util.e3_baseline_updates import (
    Gitlab,
    GitLabProjectDescription,
)
import os.path
import tarfile
import tempfile

from lib.python.gitlab_util import SPARK2014_GITLAB_ID, resolve_pipeline_id
from lib.python.suite_util import is_large, make_large, make_nonlarge

# Mapping test origin to a subdir
ORIGIN_TO_DIR = {"main": "tests", "internal": "internal", "sparklib": "sparklib"}

descr = """This script updates the outputs from a previous run of the
testsuite."""


def parse_options():
    args = None
    parser = argparse.ArgumentParser(description=descr)
    parser.add_argument(
        "-o",
        "--output-dir",
        dest="outputdir",
        help="Specify the output dir to read outputs from",
    )
    parser.add_argument(
        "--from-gaia",
        dest="gaia_id",
        help="Specify the GAIA event id to read outputs from",
    )
    parser.add_argument(
        "--from-gitlab",
        dest="gitlab_id",
        help="Specify the Gitlab merge request or pipeline id to read outputs from",
    )
    parser.add_argument(
        "--compute-time", default=False, action=argparse.BooleanOptionalAction
    )
    args = parser.parse_args()
    if (
        (args.outputdir and args.gitlab_id)
        or (args.outputdir and args.gaia_id)
        or (args.gitlab_id and args.gaia_id)
    ):
        print("please provide only one of (--output-dir, --from-gaia, --from-gitlab)")
        exit(1)
    return args


class BaselineRewriter(BaseBaselineRewriter):
    def __init__(self, colors):
        super().__init__(colors)
        self.skipped_by_origin: dict[str, list[str]] = {}
        self.warned_missing: list[tuple[str, str]] = []
        self._current_origin: str | None = None

    def baseline_filename(self, test_name: str) -> str:
        origin = self._current_origin or "main"
        prefix = ORIGIN_TO_DIR.get(origin, "tests")
        return os.path.join(prefix, test_name, "test.out")

    def rewrite_from_index(self, summary, index):
        # Copy of BaseBaselineRewriter.rewrite_from_index that takes "origin"
        # into account and saves the info in our local datastructures
        for test_name, entry in index.entries.items():
            if entry.status == TestStatus.FAIL:
                if entry.failure_reasons != {FailureReason.DIFF}:
                    self.handle_test_error(
                        summary, test_name, "test failed for another reason than a diff"
                    )
                    continue

                result = entry.load()
                assert result.env is not None
                origin = result.env.get("origin", "main")
                origin_dir = ORIGIN_TO_DIR.get(origin, "tests")

                # Skip if top-level origin directory doesn't exist locally
                if not os.path.isdir(origin_dir):
                    self.skipped_by_origin.setdefault(origin_dir, []).append(test_name)
                    continue

                # Warn if specific test directory doesn't exist
                if not os.path.isdir(os.path.join(origin_dir, test_name)):
                    self.warned_missing.append((origin_dir, test_name))
                    continue

                encoding = result.env.get("encoding", self.default_encoding)
                if result.out is None:
                    self.handle_test_error(
                        summary, test_name, "no output associated to test result"
                    )
                    continue

                self._current_origin = origin
                self.handle_test_diff(summary, test_name, result.out, encoding)
                self._current_origin = None

            elif entry.status == TestStatus.ERROR:
                self.handle_test_error(
                    summary, test_name, "test aborted because of an error"
                )


def get_single_subdir(d):
    entry = os.listdir(d)[0]
    return os.path.join(d, entry)


def download_from_gaia(gaia_id):
    g = GAIA()
    r = g.request("GET", f"event/attachment/{gaia_id}/tests_log")
    with tempfile.NamedTemporaryFile("wb", suffix=".tgz", delete=False) as f:
        for chunk in r:
            f.write(chunk)
        name = f.name
    tmpdir = tempfile.mkdtemp()
    with tarfile.open(name, mode="r:gz") as tar:
        tar.extractall(tmpdir, filter="data")
    return get_single_subdir(tmpdir)


def update_sessions_from_gaia(gaia_id):
    try:
        g = GAIA()
        r = g.request("GET", f"event/attachment/{gaia_id}/sessions.tgz")
        with tempfile.NamedTemporaryFile("wb", suffix=".tgz", delete=False) as f:
            for chunk in r:
                f.write(chunk)
            name = f.name
        tmpdir = tempfile.mkdtemp()
        with tarfile.open(name, mode="r:gz") as tar:
            tar.extractall(tmpdir)
        updated, deleted = sync_tree(tmpdir, "../..", delete=False)
        assert deleted == []
        for fn in updated:
            if os.path.isfile(fn):
                print(f"updated {fn}")
    except Exception as e:
        print(
            "warning: failed to update sessions, "
            f"possibly GAIA event doesn't have session files: {str(e)}"
        )


def compute_time(outputdir):
    report = ReportIndex.read(outputdir)
    for k, v in report.entries.items():
        if v.time is not None:
            large = is_large(k)
            if v.time > 60:
                if large:
                    pass
                else:
                    make_large(k)
            else:
                if large:
                    make_nonlarge(k)
                else:
                    pass
        else:
            print(f"No time information for test {k}")


def main():
    args = parse_options()
    if args.compute_time:
        if args.gaia_id:
            download_from_gaia(args.gaia_id)
            tmpdir = download_from_gaia(args.gaia_id)
            print(tmpdir)
            compute_time(tmpdir)
        elif args.outputdir:
            compute_time(args.outputdir)
    if args.gaia_id:
        update_sessions_from_gaia(args.gaia_id)
        tmpdir = download_from_gaia(args.gaia_id)
        outputdirs = [tmpdir]
    elif args.gitlab_id:
        p = GitLabProjectDescription(SPARK2014_GITLAB_ID, ["spark2014", "sparklib"])
        gl = Gitlab()
        pipeline_id = resolve_pipeline_id(gl, SPARK2014_GITLAB_ID, args.gitlab_id)
        outputdirs = gl.download_test_results(p, pipeline_id)
        # artifact contains a coverage subdir which should be ignored
        outputdirs = [item for item in outputdirs if "coverage" not in item]
    elif args.outputdir:
        outputdirs = [args.outputdir]
    else:
        outputdirs = [os.path.join("out", "new")]
    BR = BaselineRewriter(ColorConfig())
    for d in outputdirs:
        summary = BR.rewrite(d)
        for elt in summary.new_baselines:
            print(f"updated baseline for {elt}")
        for elt in summary.deleted_baselines:
            print(f"deleted empty baseline for {elt}")
        for elt in summary.errors:
            print(f"error updating baseline for {elt}")

    for origin_dir, tests in sorted(BR.skipped_by_origin.items()):
        print(f"\nSkipped baseline changes from {origin_dir!r}:")
        for t in sorted(tests):
            print(f"  - {t}")

    if BR.warned_missing:
        print("\nWarnings - test directory not found:")
        for origin_dir, test_name in sorted(BR.warned_missing):
            print(f"  - {os.path.join(origin_dir, test_name)}")


main()
