#!/usr/bin/env python3

import argparse
import sys
import xml.etree.ElementTree as ET
from e3.testsuite.report.index import ReportIndex
from e3.testsuite.result import TestStatus
import os
import os.path
import subprocess
import tempfile
import time
import yaml

from lib.python.suite_util import find_test_dir
from lib.python.clean_sessions import clean_session_file

descr = """This script will update the session information of a test, and then
rerun the test. It will run the test twice, so it takes some time.  """

curdir = os.getcwd()

junits = []


def parse_options():
    args = None
    parser = argparse.ArgumentParser(description=descr)
    parser.add_argument(
        "testnames",
        metavar="testnames",
        nargs="*",
        help="session of these tests will be updated",
    )
    parser.add_argument(
        "--rewrite",
        dest="rewrite",
        action="store_true",
        help="Use rewrite option to update test baselines",
    )
    parser.add_argument(
        "--failed-replay-tests",
        dest="failed_replay_tests",
        action="store_true",
        help="add failed replay tests to list of tests to rerun",
    )
    parser.add_argument(
        "--skip-rerun-tests",
        dest="skip_rerun_tests",
        action="store_true",
        help="Rerun tests after updating sessions",
    )
    parser.add_argument(
        "--resultspath",
        type=str,
        help="path to the testsuite results (used with --failed-replay-tests)",
    )
    parser.add_argument(
        "-j",
        dest="procs",
        type=int,
        help="Number of cores to use to recreate session (default: all)",
        default=0,
    )
    parser.add_argument(
        "--gitlab",
        dest="gitlab",
        action="store_true",
        help="Wrap each test output in GitLab CI foldable section markers",
    )
    parser.add_argument(
        "--junit",
        dest="junit",
        action="store_true",
        help="Generate report.xml in JUnit format",
    )
    args = parser.parse_args()
    return args


def testdir(testname):
    path = find_test_dir(testname)
    if path is None:
        print(f"error: test {testname!r} not found")
        sys.exit(1)
    return path


def is_replaytest(testname):
    d = testdir(testname)
    testyaml = os.path.join(d, "test.yaml")
    if os.path.isfile(testyaml):
        with open(testyaml, "r") as f:
            data = yaml.safe_load(f)
        if "replay" in data and data["replay"]:
            return True
    testpy = os.path.join(d, "test.py")
    if os.path.isfile(testpy):
        with open(testpy, "r") as f:
            content = f.read()
        if "def replay():" in content:
            return True
    return False


def failed_replay_tests(resultspath):
    result = []
    index = ReportIndex.read(resultspath)
    for entry in index.entries.values():
        if entry.status == TestStatus.FAIL and is_replaytest(entry.test_name):
            result.append(entry.test_name)
    return result


def clean_session_files(testdir_path):
    """Clean all why3session.xml files in the test directory."""
    session_files = []
    for root, _dirs, files in os.walk(testdir_path):
        if "why3session.xml" in files:
            session_files.append(os.path.join(root, "why3session.xml"))

    if session_files:
        print(f"Cleaning {len(session_files)} session file(s)...")
        for filepath in session_files:
            try:
                clean_session_file(filepath)
            except ET.ParseError as e:
                print(f"Warning: {filepath}: XML parse error: {e}")
            except Exception as e:
                print(f"Warning: {filepath}: error during session cleanup: {e}")


def gitlab_section_start(testname):
    section_id = testname.replace("/", "_").replace(" ", "_")
    ts = int(time.time())
    print(
        f"\x1b[0Ksection_start:{ts}:{section_id}[collapsed=true]\r\x1b[0K{testname}",
        flush=True,
    )


def gitlab_section_end(testname):
    section_id = testname.replace("/", "_").replace(" ", "_")
    ts = int(time.time())
    print(f"\x1b[0Ksection_end:{ts}:{section_id}\r\x1b[0K", flush=True)


def replay_test(args, testname):
    d = testdir(testname)
    if args.gitlab:
        gitlab_section_start(testname)
    if args.junit:
        start_time = time.time()
    try:
        print("switching to", d)
        os.chdir(d)
        cmd = os.path.dirname(__file__) + "/lib/python/replay.py"
        result = subprocess.run([cmd, "-j", str(args.procs)])
        # Clean up session files after replay
        os.chdir(curdir)
        clean_session_files(d)
    finally:
        os.chdir(curdir)
        if args.gitlab:
            gitlab_section_end(testname)
        if args.junit:
            duration = time.time() - start_time
            junits.append(
                {
                    "name": testname,
                    "time": duration,
                    "returncode": result.returncode,
                    "stdout": result.stdout,
                    "stderr": result.stderr,
                }
            )


def run_all_tests_again(args):
    print("running tests again")
    fd, tmpfile = tempfile.mkstemp()
    with os.fdopen(fd, "w") as f:
        for name in args.testnames:
            f.write(name + "\n")
    try:
        run_tests_cmd = [
            "./run-tests",
            "--disc",
            "large",
            "--diffs",
            "--testlist",
            tmpfile,
        ]
        if args.rewrite:
            run_tests_cmd.append("--rewrite")
        subprocess.run(run_tests_cmd)
    finally:
        os.remove(tmpfile)


def write_junit_report(results):
    # Build the XML tree
    testsuite = ET.Element("testsuite", name="Regenerate sessions")

    for res in results:
        testcase = ET.SubElement(
            testsuite,
            "testcase",
            name=res["name"],
            classname="session",
            time=str(round(res["time"], 4)),
        )

        # If return code is non-zero, it's a failure
        if res["returncode"] != 0:
            failure = ET.SubElement(
                testcase, "failure", message=f"Exit code: {res['returncode']}"
            )
            # Put the stderr inside the failure tag for GitLab to show
            failure.text = res["stderr"]

        # Optional: Attach full stdout for successful tests too
        system_out = ET.SubElement(testcase, "system-out")
        system_out.text = res["stdout"]

    # Write to file
    tree = ET.ElementTree(testsuite)
    ET.indent(tree, space="\t", level=0)
    tree.write("report.xml", encoding="utf-8", xml_declaration=True)


def main():
    args = parse_options()
    testnames = args.testnames
    if args.failed_replay_tests:
        resultspath = (
            args.resultspath if args.resultspath else os.path.join("out", "new")
        )
        testnames += failed_replay_tests(resultspath)
    if len(testnames) == 0:
        print("no tests to replay")
        exit(0)
    for testname in testnames:
        replay_test(args, testname)
    if not args.skip_rerun_tests:
        run_all_tests_again(args)
    if args.junit:
        write_junit_report(junits)


main()
