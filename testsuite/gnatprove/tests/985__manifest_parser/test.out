===== valid manifest =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
kind = "procedure"
profile = "()"
timeout = 1
steps = 100
memlimit = 1000
level = 2
provers = ["cvc5", "z3"]

[[subprogram]]
path = "Main.Inner"
kind = "procedure"
profile = "(_ : Integer)"
steps = 200
--- output ---
===== unit and package manifest =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
steps = 1

[[subprogram]]
path = "Main"
kind = "package"
hierarchical = false
steps = 2
--- output ---
===== unit and nested package manifest =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
steps = 1

[[subprogram]]
path = "Main.Nested"
kind = "package"
hierarchical = false
steps = 2
--- output ---
===== unknown field =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
unknown = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest unknown_field/main.toml:5:11: unknown field "unknown"
===== bad provers syntax =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
provers = "cvc5"
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest bad_provers_syntax/main.toml:5:11: field "provers" must be an array
===== missing path =====
--- manifest main.toml ---
version = 1

[[subprogram]]
timeout = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest missing_path/main.toml:3:1: missing required field "path"
===== missing version =====
--- manifest main.toml ---
[[subprogram]]
path = "Main"
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest missing_version/main.toml: missing required field "version"
===== unsupported version =====
--- manifest main.toml ---
version = 2

[[subprogram]]
path = "Main"
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest unsupported_version/main.toml:1:10: unsupported version, expected 1
===== missing folder =====
Try "gnatprove --help" for more information.
error: proof manifest folder "missing_manifest" does not exist
===== file instead of folder =====
Try "gnatprove --help" for more information.
error: proof manifest "main.adb" is not a folder
===== wrong unit =====
--- manifest other.toml ---
version = 1

[[subprogram]]
path = "Main"
steps = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest wrong_unit/other.toml:4:8: path "Main" does not belong to manifest unit "other"
===== bad kind =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
kind = "task"
steps = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest bad_kind/main.toml:5:8: field "kind" must be one of "package", "procedure" or "function"
===== profile without kind =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
profile = "()"
steps = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest profile_without_kind/main.toml:5:11: field "profile" requires kind "procedure" or "function"
===== bad hierarchical =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
hierarchical = "false"
steps = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest bad_hierarchical/main.toml:5:16: field "hierarchical" must be a boolean
===== package profile =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
kind = "package"
profile = "()"
steps = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest package_profile/main.toml:6:11: field "profile" requires kind "procedure" or "function"
===== no options =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest no_options/main.toml:3:1: missing proof option
===== bad level =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
level = 5
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest bad_level/main.toml:5:9: field "level" must be between 0 and 4
===== duplicate entry =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
steps = 1

[[subprogram]]
path = "Main"
timeout = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest duplicate_entry/main.toml:7:1: duplicate manifest entry
===== duplicate prover =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main"
provers = ["cvc5", "cvc5"]
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest duplicate_prover/main.toml:5:20: duplicate prover "cvc5"
===== bad path =====
--- manifest main.toml ---
version = 1

[[subprogram]]
path = "Main..Inner"
steps = 1
--- output ---
Try "gnatprove --help" for more information.
error: invalid proof manifest bad_path/main.toml:4:8: field "path" must be a dot-separated Ada name
