library project Counter_Lib is

   for Library_Name use "counter";
   for Library_Kind use "static";
   for Library_Dir use "lib";
   for Object_Dir use "obj";
   for Source_Dirs use ("lib_src");

   --  No special configuration is needed to install the summary ALI files
   --  produced by GNATprove: gprinstall copies the "gnatprove" subfolder of
   --  the library directory automatically.

end Counter_Lib;
