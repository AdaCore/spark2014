project linear_search_contract is

   for Source_Dirs use (".");
   for Main use ("test_search.adb", "test_search.adb");

   package Compiler is
      for Switches ("ada") use ("-gnatwa", "-gnata", "-g", "-O0");
   end Compiler;

   package Pretty_Printer is
      for Default_Switches ("ada") use ("-aU");
   end Pretty_Printer;

   package Prove is
      for Proof_Switches ("Ada") use ("--level=2");
   end Prove;

end linear_search_contract;
